# Andmebaas (Docker Compose kasutab neid samu väärtusi, vt docker-compose.yml)
DATABASE_URL="postgresql://lahematix:lahematix_dev_pw@localhost:5432/lahematix?schema=public"

# Sessiooni krüpteerimisvõti (iron-session) — PEAB olema vähemalt 32 tähemärki.
# Genereeri oma: openssl rand -base64 32
SESSION_SECRET="muuda_see_ara_vahemalt_32_tahemarki_pikk_saladus"

# SMTP (zone.ee oma e-posti teenus) — kutsete ja teavituste saatmiseks
SMTP_HOST="smtp.zone.eu"
SMTP_PORT=587
SMTP_USER="lahematix@lahemate.ee"
SMTP_PASSWORD="muuda_see_ara"
SMTP_FROM="LAHEMATE projekt <lahematix@lahemate.ee>"

# Rakenduse baas-URL (kutsete linkide ja token-URL-ide genereerimiseks)
APP_BASE_URL="http://localhost:3000"

# NB! HarID seaded lisatakse siia Faasis 5, kui SAML-liides on kolleegidega

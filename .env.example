# Database — the value below is correct for local DDEV development, where Postgres
# runs in the DDEV "db" service (default credentials db/db/db).
DATABASE_URL="postgresql://db:db@db:5432/db?schema=public"

# Session encryption key (iron-session) — MUST be at least 32 characters.
# Generate your own: openssl rand -base64 32
SESSION_SECRET="change_me_at_least_32_characters_long_secret"

# SMTP (Zone email service) — for sending invites and notifications.
# Can stay as placeholders in local dev: login links are printed to the log
# instead of emailed (see README).
SMTP_HOST="smtp.zone.eu"
SMTP_PORT=587
SMTP_USER="lahematix@lahemate.ee"
SMTP_PASSWORD="change_me"
SMTP_FROM="LAHEMATE projekt <lahematix@lahemate.ee>"

# App base URL — used to generate invite/token links. For local DDEV this matches
# the exposed dev-server port.
APP_BASE_URL="https://lahematix.ddev.site:3000"

# NB! HarID settings will be added here once the SAML integration is ready
# (e.g. HARID_SP_ENTITY_ID, HARID_IDP_METADATA_URL, HARID_CERT, etc.).
# Until then the app uses simple DEV_LOGIN authentication (see README.md).

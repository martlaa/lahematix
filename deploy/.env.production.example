# Production environment (Hetzner). Copy to /opt/lahematix/.env and fill in.
# This file is read BOTH by docker-compose.prod.yml (variable interpolation for
# the db service) AND passed into the app/migrate containers via env_file.

# --- PostgreSQL (db service) ---
# POSTGRES_PASSWORD must match the password inside DATABASE_URL below.
POSTGRES_USER=lahematix
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=lahematix

# --- App database connection ---
# Host "db" is the compose service name (internal Docker network).
DATABASE_URL="postgresql://lahematix:CHANGE_ME_strong_db_password@db:5432/lahematix?schema=public"

# --- Session secret (iron-session), min 32 chars ---
# Generate on the server: openssl rand -base64 32
SESSION_SECRET="CHANGE_ME_min_32_chars"

# --- SMTP (Zone) — REQUIRED in production for login links + invites ---
SMTP_HOST="smtp.zone.eu"
SMTP_PORT=587
SMTP_USER="lahematix@lahemate.ee"
SMTP_PASSWORD="CHANGE_ME_zone_mailbox_password"
SMTP_FROM="LAHEMATE projekt <lahematix@lahemate.ee>"

# --- Public URL — MUST match the hostname in deploy/Caddyfile ---
APP_BASE_URL="https://app.lahemate.ee"

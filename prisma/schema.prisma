// LAHEMATIX andmemudel — Faas 1 (autentimine + nõusolekud)
// NB! Faas 2 lisab: LessonPlan, ObservationProtocol, JournalEntry,
// Questionnaire/QuestionnaireResponse, TestVersion/TestSubmission.
// Need on siia juba kommentaarina ette valmistatud, aga mudelid
// lisatakse Faasis 2, et Faas 1 jääks väiksemaks ja kergemini
// ülevaadatavaks.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  TEADUR
  OPETAJA
  KOOLIJUHT
  LAPSEVANEM
}

enum Method {
  BOALER
  LILJEDAHL
  TOH
}

enum StudentGroup {
  INTERVENTSIOON
  KONTROLL
}

enum ConsentSubjectType {
  KOOLIJUHT
  OPETAJA
  LAPSEVANEM
  OPILANE_15PLUS
}

enum ConsentStatus {
  ANTUD
  TAGASI_VOETUD
}

enum AuthMethod {
  HARID // ei ole kasutusel (versioon 3 loobus HarID-st); säilib ainult skeemi ühilduvuse pärast
  TOKEN_URL
  DEV_LOGIN // endine ajutine paroolita sisselogimine; asendatud EMAIL_LINK'iga, säilib vanade kirjete jaoks
  EMAIL_LINK // magic-link sisselogimine (versioon 3, püsiv lahendus)
}

// Faas 2: InviteToken eesmärk — kas nõusolek (vaikimisi, olemasolevad read) või
// küsimustik (eel/järel). Küsimustiku token saadetakse alati õpilase enda e-postile,
// isegi alla 15-aastasele, kuna küsimustik käib õpilase enda kohta, mitte lapsevanema.
enum InvitePurpose {
  CONSENT
  QUESTIONNAIRE_EEL
  QUESTIONNAIRE_JAREL
  TEST_EEL
  TEST_JAREL
}

// Faas 2: matemaatilise probleemilahenduse test. Sama test käib eel- ja
// järelmõõtmisel (phase eristab neid), sisu on hardcoded src/lib/tests/-is.
enum TestPhase {
  EEL
  JAREL
}

// Faas 1 jätk: tunnikava (Lisa 11) tunniosa tüüp — rippmenüü väärtused
// õpetaja enda sõnastatud tunnikava jaoks.
enum LessonPartType {
  OPETAJA_ESITLUS
  INDIVIDUAALNE_HARJUTAMINE
  INDIVIDUAALNE_PROBLEEMILAHENDUS
  PROBLEEMILAHENDUS_RUHMATOONA
  UHINE_ARUTELU
  REFLEKSIOON
}

enum CommentTiming {
  ENNE
  JAREL
}

// --- Kasutajad (täiskasvanud rollid) ---

model User {
  id             String   @id @default(cuid())
  role           Role
  email          String   @unique
  name           String
  haridSubjectId String?  @unique // täidetakse, kui HarID on ühendatud
  status         String   @default("ACTIVE") // ACTIVE | INVITED | DISABLED
  identityDeletedAt DateTime? // täidetud, kui admin on identifitseerivad väljad (nimi/e-post) jäädavalt kustutanud
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // rollipõhised laiendused (valikulised, ainult üks täidetud vastavalt rollile)
  teacherProfile Teacher?

  auditLogs   AuditLog[]
  loginTokens LoginToken[]
  questionnaireResponses QuestionnaireResponse[]
  testGradings TestGrading[]
  observedEntries       ResearchPlanEntry[]   @relation("Observer")
  lessonPlanComments    LessonPlanComment[]
  observationProtocols  ObservationProtocol[]
  sampleLessonPlans     SampleLessonPlan[]
  instrumentTrials      InstrumentTrial[]
  exportRequestsMade    ExportRequest[]       @relation("ExportRequestedBy")
  exportRequestsDecided ExportRequest[]       @relation("ExportDecidedBy")
  appSettingsClosedBy   AppSettings[]
  tasks                 Task[]
  taskRatings           TaskRating[]

  @@index([role])
}

// Versioon 5: koolijuht ei ole enam eraldi kasutajakonto (vt arendusplaan punkt 1b) —
// tema nimi/e-post on lihtsalt väljad School'il, ja ta pääseb ligi ainult ühekordse
// token-URL-i kaudu (InviteToken), samamoodi nagu lapsevanem ja 15+ õpilane.

model School {
  id            String    @id @default(cuid())
  name          String
  directorName  String?
  directorEmail String?
  consentGiven  Boolean   @default(false)
  consentAt     DateTime?
  createdAt     DateTime  @default(now())

  teachers     Teacher[]
  inviteTokens InviteToken[]
}

model Teacher {
  id        String       @id @default(cuid())
  pseudonymCode String   @unique // nt "OU-4F7A2B" — kasutatakse uurimisandmestikus (eetikataotlus p 4.1)
  userId    String       @unique
  user      User         @relation(fields: [userId], references: [id])
  schoolId  String
  school    School       @relation(fields: [schoolId], references: [id])
  method    Method?
  group     StudentGroup @default(INTERVENTSIOON)
  gradeBand String? // "4-6" | "7-9" | "10-12"
  lisa8FirstViewedAt DateTime? // millal õpetaja Lisa 8 küsimustiku esimest korda avas — "alustatud, pooleli" märgistuseks
  createdAt DateTime     @default(now())

  students Student[]
  researchPlanEntries ResearchPlanEntry[]
  journalEntries      JournalEntry[]
}

// --- Õpilased (ei ole User — token-põhine ligipääs, vt InviteToken) ---
// Versioon 4: lapsevanem ei ole enam eraldi kasutajakonto (vt arendusplaan punkt 1a) —
// tema nimi/e-post on lihtsalt väljad Student'il, ja ta pääseb ligi ainult ühekordse
// token-URL-i kaudu (InviteToken), samamoodi nagu 15+ õpilane ise.

model Student {
  id                  String       @id @default(cuid())
  pseudonymCode       String       @unique // nt "OP-4F7A2B" — kasutatakse uurimisandmestikus (testid, küsimustikud)
  name                String       // õpilase pärisnimi — vajalik õpetaja klassivaate ja kutsete jaoks
  email               String       @unique // vajalik küsimustiku/testi kutsete saatmiseks
  classCode           String?      // vaba tekst, nt "5A" — õpetaja enda klassi/rühma silt, hilisemaks filtreerimiseks
  teacherId           String
  teacher             Teacher      @relation(fields: [teacherId], references: [id])
  group               StudentGroup
  birthYear           Int?
  gender              String?
  isFifteenOrOlder    Boolean      @default(false)
  parentName          String? // täidetud, kui alla 15a — ei ole eraldi kasutajakonto
  parentEmail         String? // täidetud, kui alla 15a — kutse/meeldetuletuse saatmiseks
  excludedFromAnalysis Boolean     @default(false)
  excludedAt          DateTime?
  identityDeletedAt   DateTime? // täidetud, kui admin on nime/e-posti/lapsevanema andmed jäädavalt kustutanud
  createdAt           DateTime     @default(now())

  consentRecords ConsentRecord[]
  inviteTokens   InviteToken[]
  questionnaireResponses QuestionnaireResponse[]
  testSubmissions TestSubmission[]
}

// --- Nõusolekud ---

model ConsentRecord {
  id          String             @id @default(cuid())
  subjectType ConsentSubjectType
  // subjectId viitab: User.id (õpetaja), School.id (koolijuht, versioon 5) või
  // Student.id (lapsevanem, versioon 4; 15+ õpilane)
  subjectId   String
  studentId   String? // täidetud, kui nõusolek puudutab konkreetset last (lapsevanema puhul)
  student     Student?           @relation(fields: [studentId], references: [id])
  formVersion String             @default("v1")
  status      ConsentStatus      @default(ANTUD)
  givenAt     DateTime           @default(now())
  withdrawnAt DateTime?
  authMethod  AuthMethod
  // granulaarsed nõusolekukastid (Lisa 2 õpetaja vormi jaoks kolm eraldi kasti;
  // teiste vormide jaoks piisab esimesest väljast)
  detailsJson String? // JSON: { osalemine: true, vaatlus: true, intervjuu: false, ... }

  createdAt DateTime @default(now())

  @@index([subjectType, subjectId])
  @@index([studentId])
}

// --- Kutsed ja ühekordsed lingid ---

model InviteToken {
  id         String        @id @default(cuid())
  token      String        @unique
  // kutse sihtmärk: kas uus User (email+role täidetud), Student (studentId täidetud)
  // või School (schoolId täidetud, koolijuhi jaoks, versioon 5)
  email      String?
  role       Role?
  studentId  String?
  student    Student?      @relation(fields: [studentId], references: [id])
  schoolId   String?
  school     School?       @relation(fields: [schoolId], references: [id])
  purpose    InvitePurpose @default(CONSENT)
  expiresAt  DateTime
  usedAt     DateTime?
  firstViewedAt DateTime? // millal link esimest korda avati — "alustatud, kuid pooleli" märgistuse jaoks
  createdAt  DateTime      @default(now())
}

// --- Sisselogimislingid (magic link, versioon 3) ---

model LoginToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime // 15 minutit väljastamisest
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// --- Küsimustikud (Faas 2) ---
// Küsimustiku struktuur (plokid, väited) on hardcoded src/lib/questionnaires/-is,
// mitte DB-mudel — samamoodi nagu nõusolekuvormide tekst elab consentTexts.tsx-is.
// questionnaireCode viitab lihtsalt stringkoodile (nt "lisa4-eel", "lisa8"),
// samamoodi nagu ConsentRecord.formVersion on lihtne string, mitte FK.

model QuestionnaireResponse {
  id                String   @id @default(cuid())
  questionnaireCode String
  studentId         String?
  student           Student? @relation(fields: [studentId], references: [id])
  teacherUserId     String?
  teacherUser       User?    @relation(fields: [teacherUserId], references: [id])
  answersJson       String // { [blockKey]: { [itemKey]: string|number } }
  submittedAt       DateTime @default(now())

  @@unique([questionnaireCode, studentId])
  @@unique([questionnaireCode, teacherUserId])
}

// --- Matemaatilise probleemilahenduse test (Faas 2) ---
// Testi sisu (ülesanded, valikvastused, hindamisjuhend) on hardcoded
// src/lib/tests/-is, samamoodi nagu küsimustikud. Sama test käib eel- ja
// järelmõõtmisel ning nii kontroll- kui katserühmale — phase eristab
// mõõtmiskorda, testCode vanuseastet ("test-4-6" | "test-7-9" | "test-10-12").

model TestSubmission {
  id          String    @id @default(cuid())
  testCode    String
  phase       TestPhase
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  answersJson String? // null, kui ainult paberifotod; muidu { [probleemKey]: { [subKey]: { choice, explanation? } } }
  submittedAt DateTime? // täidetud, kui õpilane ise veebis sooritas
  createdAt   DateTime  @default(now())

  photos  TestSubmissionPhoto[]
  grading TestGrading?

  @@unique([testCode, phase, studentId])
}

model TestSubmissionPhoto {
  id               String         @id @default(cuid())
  testSubmissionId String
  testSubmission   TestSubmission @relation(fields: [testSubmissionId], references: [id])
  filePath         String // suhteline tee privaatses uploads-kaustas
  originalName     String
  uploadedAt       DateTime       @default(now())

  @@index([testSubmissionId])
}

model TestGrading {
  id               String         @id @default(cuid())
  testSubmissionId String         @unique
  testSubmission   TestSubmission @relation(fields: [testSubmissionId], references: [id])
  scoresJson       String // { [probleemKey]: { [subKey]: number } }
  totalScore       Int
  comment          String? // nähtav ainult õpetajale, teadurile ja adminile
  gradedByUserId   String
  gradedByUser     User           @relation(fields: [gradedByUserId], references: [id])
  gradedAt         DateTime       @default(now())
}

// --- Õpetaja isiklik uuringukava ja uurijapäevik (Faas 1 jätk, Lisa 7 + Lisa 10) ---
// Uuringukava rida kirjeldab ühte plaanitud katsetundi; õpetaja lisab/muudab/
// kustutab ridu ise jooksvalt (vt Lisa 10 juhis — tabel ei pea korraga täielik
// olema). observerUserId viitab konkreetsele teisele õpetajale-uurijale või
// teadurile, kellel on LAHEMATIX konto — tema pääseb sellele reale ligi
// vaatlejana (tunnikava lugemine + kommenteerimine + vaatlusprotokoll).

model ResearchPlanEntry {
  id                String    @id @default(cuid())
  teacherId         String
  teacher           Teacher   @relation(fields: [teacherId], references: [id])
  date              DateTime
  startTime         String? // kellaaeg, nt "10:15"
  durationMin       Int?
  studentGroup      String? // nt "5A"
  appliedMethods    Method[]  @default([]) // selle tunni jooksul tegelikult rakendatud meetod(id)
  topic             String?
  expectingObserver Boolean   @default(false)
  observerName      String? // vaba tekst, säilib kuvamiseks (nt kui kontot veel pole)
  observerUserId    String?
  observerUser      User?     @relation("Observer", fields: [observerUserId], references: [id])
  hidden            Boolean   @default(false) // "Peida"/"Taasta" — pehme peitmine, mitte kustutamine
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  journalEntry JournalEntry?
  lessonPlan   LessonPlan?

  @@index([teacherId])
  @@index([observerUserId])
}

// Tunnikava (Lisa 11) — kuulub ühele uuringukava reale (1:1). Tunniosad
// (LessonPlanPart) on eraldi tabel, kuna neid on muutuv arv (3–6) ja iga
// osa kohta peab tunnivaatlusprotokoll (Lisa 6c) pidama eraldi intsidentide
// logi.

model LessonPlan {
  id                  String   @id @default(cuid())
  researchPlanEntryId String   @unique
  researchPlanEntry   ResearchPlanEntry @relation(fields: [researchPlanEntryId], references: [id])
  materialsJson       String? // { slaidid?, toolehed?, ulesanded?, opik?, kahoot?, muu? } — väärtus = link/tekst, võti olemas = linnuke märgitud
  homeworkText        String?
  homeworkRelated     Boolean  @default(false) // kas kodutöö on otseselt seotud tänase tunni teemaga
  publishedToGalleryAt DateTime? // õpetaja nõusolek avaldada see tunnikava avalikus galeriis (Faas 5), CC-BY
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Tunnikavade jada (õpetaja märgib, et see tund jätkab eelmist) — @unique
  // previousLessonPlanId peal tagab, et igal tunnil on ülimalt üks "järgmine"
  // tund, nii jääb jada haruteta lihtsaks lingitud nimekirjaks.
  previousLessonPlanId String?     @unique
  previousLessonPlan   LessonPlan? @relation("LessonPlanSequence", fields: [previousLessonPlanId], references: [id], onDelete: SetNull)
  nextLessonPlan       LessonPlan? @relation("LessonPlanSequence")

  parts                LessonPlanPart[]
  comments             LessonPlanComment[]
  observationProtocols ObservationProtocol[]
  taskUsages           TaskUsage[]
}

model LessonPlanPart {
  id           String         @id @default(cuid())
  lessonPlanId String
  lessonPlan   LessonPlan     @relation(fields: [lessonPlanId], references: [id])
  order        Int
  title        String
  type         LessonPartType
  durationMin  Int
  description  String?
  observerNote String? // "Vaatlejale" vihje — valikuline

  @@index([lessonPlanId])
}

// Vaatleja kommentaarid tunnikavale — enne katsetundi ja pärast seda.

model LessonPlanComment {
  id           String        @id @default(cuid())
  lessonPlanId String
  lessonPlan   LessonPlan    @relation(fields: [lessonPlanId], references: [id])
  authorUserId String
  authorUser   User          @relation(fields: [authorUserId], references: [id])
  timing       CommentTiming
  text         String
  createdAt    DateTime      @default(now())

  @@index([lessonPlanId])
}

// Tunnivaatlusprotokoll (Lisa 6c) — kahes osas: (1) ratingsJson on ÜKS
// struktureeritud TRU hinnang tunnile TERVIKUNA (itemKey -> {value, note}),
// täidetav üks kord tunni lõpus; (2) incidentsJson on ajatempliga sündmuste
// logi, kus iga kirje viitab konkreetsele LessonPlanPart.id-le (tunniosale),
// mille juures see aset leidis. Iga vaatleja (kellel LAHEMATIX konto —
// õpetaja-uurija või teadur) täidab oma protokolli; sama tunnikava kohta
// võib olla mitu vaatlejat (reliaabluse kontroll, vt Lisa 6c juhend).

model ObservationProtocol {
  id             String     @id @default(cuid())
  lessonPlanId   String
  lessonPlan     LessonPlan @relation(fields: [lessonPlanId], references: [id])
  observerUserId String
  observerUser   User       @relation(fields: [observerUserId], references: [id])
  ratingsJson    String? // { M1: {value, note}, ..., MT1: {value, note} } — terve tunni kohta, mitte tunniosade kaupa
  incidentsJson  String? // [{ lessonPlanPartId, timeMin, description, constructs: string[], whoWith }]
  summaryJson    String? // { shortSummary, methodFidelity, surprises, recommendations }
  submittedAt    DateTime?
  publishedAt    DateTime? // täidetud alles siis, kui vaatleja otsustab protokolli õpetajale nähtavaks teha
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([lessonPlanId, observerUserId])
}

// Uurijapäeviku sissekanne (Lisa 7) — üks kindla katsetunni kohta, kirjutatakse
// kohe pärast tundi. Sisu (9 Likert-väidet + Rolfe'i refleksioon) on hardcoded
// src/lib/journal/-is, samamoodi nagu küsimustikud/testid. Õpetaja saab
// sissekannet hiljem täiendada/muuta — submittedAt on esmase salvestuse aeg,
// updatedAt uueneb iga muutmisega.

model JournalEntry {
  id                  String            @id @default(cuid())
  researchPlanEntryId String            @unique
  researchPlanEntry   ResearchPlanEntry @relation(fields: [researchPlanEntryId], references: [id])
  teacherId           String
  teacher             Teacher           @relation(fields: [teacherId], references: [id])
  answersJson         String // { likert: { [domainKey.itemKey]: { value, comment? } }, rolfe: { what: [s1,s2,s3], soWhat, nowWhat } }
  submittedAt         DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

// Teaduri näidistunnikava — sama tunniosade struktuur mis õpetaja tunnikaval
// (Lisa 11), aga ilma kooli/kuupäeva kontekstita, kuna teadur ei vii ise
// tundi läbi. Eesmärk on pakkuda õpetajatele nende endi tunnikava koostamisel
// eeskuju sama vanuseastme, meetodi või teema kohta.

model SampleLessonPlan {
  id              String   @id @default(cuid())
  authorUserId    String
  authorUser      User     @relation(fields: [authorUserId], references: [id])
  gradeBand       String? // "4-6" | "7-9" | "10-12"
  appliedMethods  Method[] @default([])
  topic           String?
  durationMin     Int?
  materialsJson   String?
  homeworkText    String?
  homeworkRelated Boolean  @default(false)
  hidden          Boolean  @default(false)
  publishedToGalleryAt DateTime? // teaduri nõusolek avaldada see näidistund avalikus galeriis (Faas 5), CC-BY
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Näidistundide jada (sama muster mis LessonPlan.previousLessonPlanId) —
  // teadur saab märkida, et üks näidistund jätkab otseselt tema teist
  // näidistundi, moodustades näidiseks tervikliku järjestikuste tundide komplekti.
  previousSampleLessonPlanId String?           @unique
  previousSampleLessonPlan   SampleLessonPlan? @relation("SampleLessonPlanSequence", fields: [previousSampleLessonPlanId], references: [id], onDelete: SetNull)
  nextSampleLessonPlan       SampleLessonPlan? @relation("SampleLessonPlanSequence")

  parts       SampleLessonPlanPart[]
  taskUsages  SampleTaskUsage[]

  @@index([authorUserId])
}

model SampleLessonPlanPart {
  id                 String           @id @default(cuid())
  sampleLessonPlanId String
  sampleLessonPlan   SampleLessonPlan @relation(fields: [sampleLessonPlanId], references: [id])
  order              Int
  title              String
  type               LessonPartType
  durationMin        Int
  description        String?

  @@index([sampleLessonPlanId])
}

// Teaduri instrumendikatsetus — võimaldab teaduril iga uuringus kasutatava
// instrumendi (küsimustikud, uurijapäevik, testid, tunnivaatlusprotokoll) ise
// läbi katsetada, ilma et see saastaks päris uuringuandmestikku (Student/
// Teacher-põhiseid mudeleid). instrumentCode kannab konteksti: enamiku
// instrumentide puhul on see lihtsalt olemasolev sisukood ("lisa4-eel",
// "lisa8", "test-7-9" jne), tunnivaatlusprotokolli puhul on lisatud
// näidistunnikava id ("lisa6:<sampleLessonPlanId>"), kuna checkpointid
// tulevad dünaamiliselt sellest näidistunnist.

model InstrumentTrial {
  id             String    @id @default(cuid())
  authorUserId   String
  authorUser     User      @relation(fields: [authorUserId], references: [id])
  instrumentCode String
  answersJson    String?
  gradingJson    String? // ainult testide jaoks
  totalScore     Int? // ainult testide jaoks
  gradingComment String? // ainult testide jaoks
  submittedAt    DateTime?
  gradedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([authorUserId, instrumentCode])
}

// --- Ülesannete pank (Faas 6): õpetajate ettepanekul lisatud jagatud
// õppematerjalide/ülesannete kogu, avalik nagu tunnikavade galerii. Nii
// õpetajad kui teadurid saavad ülesandeid lisada. Ülesande sisu on kas
// väline link (GDocs/OneDrive) või üleslaetud fail (docx/jpg/pdf, kuni
// 50 MB), mis salvestatakse privaatsesse uploads/task-bank kausta ja
// serveeritakse vahendatud (loenduva) route'i kaudu, mitte public/ kaudu.
// Populaarsuse näitajad: downloadCount (loendatakse nii faili- kui
// lingiallalaadimisi), TaskUsage (taaskasutamine tunnikavades) ja
// TaskRating (kasutajate 1-5 hinnang, üks hinnang kasutaja kohta).

model Task {
  id             String   @id @default(cuid())
  authorUserId   String
  authorUser     User     @relation(fields: [authorUserId], references: [id])
  title          String
  gradeBand      String? // "4-6" | "7-9" | "10-12"
  topic          String?
  appliedMethods Method[] @default([])
  creditedAuthor String? // ülesande algallika autor (kui erineb üleslaadijast)
  worksheetUrl   String? // väline link (GDocs/OneDrive)
  filePath       String? // suhteline tee privaatses uploads/task-bank kaustas
  fileName       String? // originaalnimi
  fileMime       String?
  fileSizeBytes  Int?
  hidden         Boolean  @default(false)
  downloadCount  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  usages       TaskUsage[]
  sampleUsages SampleTaskUsage[]
  ratings      TaskRating[]

  @@index([authorUserId])
}

model TaskUsage {
  id           String     @id @default(cuid())
  taskId       String
  task         Task       @relation(fields: [taskId], references: [id])
  lessonPlanId String
  lessonPlan   LessonPlan @relation(fields: [lessonPlanId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([taskId, lessonPlanId])
  @@index([lessonPlanId])
}

// Ülesande kasutus teaduri NÄIDISTUNNIKAVAL (eraldi tabel TaskUsage'ist,
// kuna näidistunnikavad on SampleLessonPlan, mitte LessonPlan — mõlemad
// loevad kokku Task'i "Tunnikavades" populaarsuse näitaja, vt taskbank.ts).
model SampleTaskUsage {
  id                 String           @id @default(cuid())
  taskId             String
  task               Task             @relation(fields: [taskId], references: [id])
  sampleLessonPlanId String
  sampleLessonPlan   SampleLessonPlan @relation(fields: [sampleLessonPlanId], references: [id])
  createdAt          DateTime         @default(now())

  @@unique([taskId, sampleLessonPlanId])
  @@index([sampleLessonPlanId])
}

model TaskRating {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  value     Int // 1-5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([taskId, userId])
}

// --- Andmete eluring (Faas 4 jätk): ekspordilubade taotlemine, andmete
// kustutamine ja rakenduse sulgemine ---

enum ExportRequestStatus {
  PENDING
  APPROVED
  DENIED
  FULFILLED
}

// Tundlike andmestike (õpilaste/õpetajate küsimustikud, testitulemused,
// uurijapäevik) eksport ei ole teadurile vaba — iga kord tuleb taotleda
// admini kinnitus. Kinnitus on ühekordne: pärast allalaadimist (fulfilledAt)
// läheb taotlus suletuks ja uue ekspordi jaoks tuleb uus taotlus esitada.
model ExportRequest {
  id                String              @id @default(cuid())
  requestedByUserId String
  requestedByUser   User                @relation("ExportRequestedBy", fields: [requestedByUserId], references: [id])
  datasetKey        String
  status            ExportRequestStatus @default(PENDING)
  requestedAt       DateTime            @default(now())
  decidedByUserId   String?
  decidedByUser     User?               @relation("ExportDecidedBy", fields: [decidedByUserId], references: [id])
  decidedAt         DateTime?
  decisionNote      String?
  fulfilledAt       DateTime?

  @@index([requestedByUserId])
  @@index([status])
}

// Rakenduse üldine olek (singleton rida, id on alati "singleton") —
// hetkel ainult sulgemise oleku jaoks.
model AppSettings {
  id             String    @id @default("singleton")
  closedAt       DateTime?
  closedByUserId String?
  closedByUser   User?     @relation(fields: [closedByUserId], references: [id])
  reopenedAt     DateTime?
}

// --- Audit log ---

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  entity    String
  entityId  String
  meta      String? // JSON
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}

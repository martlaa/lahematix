// LAHEMATIX andmemudel — Faas 1 (autentimine + nõusolekud)
// NB! Faas 2 lisab: LessonPlan, ObservationProtocol, JournalEntry,
// Questionnaire/QuestionnaireResponse, TestVersion/TestSubmission.
// Need on siia juba kommentaarina ette valmistatud, aga mudelid
// lisatakse Faasis 2, et Faas 1 jääks väiksemaks ja kergemini
// ülevaadatavaks.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  TEADUR
  OPETAJA
  KOOLIJUHT
  LAPSEVANEM
}

enum Method {
  BOALER
  LILJEDAHL
  TOH
}

enum StudentGroup {
  INTERVENTSIOON
  KONTROLL
}

enum ConsentSubjectType {
  KOOLIJUHT
  OPETAJA
  LAPSEVANEM
  OPILANE_15PLUS
}

enum ConsentStatus {
  ANTUD
  TAGASI_VOETUD
}

enum AuthMethod {
  HARID
  TOKEN_URL
  DEV_LOGIN // ajutine, ainult Faas 1 arenduse ajaks, eemaldatakse enne HarID kasutuselevõttu
}

// --- Kasutajad (täiskasvanud rollid) ---

model User {
  id             String   @id @default(cuid())
  role           Role
  email          String   @unique
  name           String
  haridSubjectId String?  @unique // täidetakse, kui HarID on ühendatud
  status         String   @default("ACTIVE") // ACTIVE | INVITED | DISABLED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // rollipõhised laiendused (valikulised, ainult üks täidetud vastavalt rollile)
  teacherProfile   Teacher?
  directorOfSchool School?  @relation("SchoolDirector")
  parentProfile    Parent?

  auditLogs AuditLog[]

  @@index([role])
}

model School {
  id           String   @id @default(cuid())
  name         String
  directorId   String?  @unique
  director     User?    @relation("SchoolDirector", fields: [directorId], references: [id])
  consentGiven Boolean  @default(false)
  consentAt    DateTime?
  createdAt    DateTime @default(now())

  teachers Teacher[]
}

model Teacher {
  id        String       @id @default(cuid())
  userId    String       @unique
  user      User         @relation(fields: [userId], references: [id])
  schoolId  String
  school    School       @relation(fields: [schoolId], references: [id])
  method    Method?
  group     StudentGroup @default(INTERVENTSIOON)
  gradeBand String? // "4-6" | "7-9" | "10-12"
  createdAt DateTime     @default(now())

  students Student[]
}

model Parent {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  students Student[]
}

// --- Õpilased (ei ole User — token-põhine ligipääs, vt InviteToken) ---

model Student {
  id                  String       @id @default(cuid())
  pseudonymCode       String       @unique // nt "OP-4F7A2B"
  teacherId           String
  teacher             Teacher      @relation(fields: [teacherId], references: [id])
  group               StudentGroup
  birthYear           Int?
  gender              String?
  isFifteenOrOlder    Boolean      @default(false)
  parentId            String?
  parent              Parent?      @relation(fields: [parentId], references: [id])
  excludedFromAnalysis Boolean     @default(false)
  excludedAt          DateTime?
  createdAt           DateTime     @default(now())

  consentRecords ConsentRecord[]
  inviteTokens   InviteToken[]
}

// --- Nõusolekud ---

model ConsentRecord {
  id          String             @id @default(cuid())
  subjectType ConsentSubjectType
  // subjectId viitab kas User.id (koolijuht/õpetaja/lapsevanem) või Student.id (15+ õpilane)
  subjectId   String
  studentId   String? // täidetud, kui nõusolek puudutab konkreetset last (lapsevanema puhul)
  student     Student?           @relation(fields: [studentId], references: [id])
  formVersion String             @default("v1")
  status      ConsentStatus      @default(ANTUD)
  givenAt     DateTime           @default(now())
  withdrawnAt DateTime?
  authMethod  AuthMethod
  // granulaarsed nõusolekukastid (Lisa 2 õpetaja vormi jaoks kolm eraldi kasti;
  // teiste vormide jaoks piisab esimesest väljast)
  detailsJson String? // JSON: { osalemine: true, vaatlus: true, intervjuu: false, ... }

  createdAt DateTime @default(now())

  @@index([subjectType, subjectId])
  @@index([studentId])
}

// --- Kutsed ja ühekordsed lingid ---

model InviteToken {
  id         String    @id @default(cuid())
  token      String    @unique
  // kutse sihtmärk: kas uus User (email+role täidetud) või Student (studentId täidetud)
  email      String?
  role       Role?
  studentId  String?
  student    Student?  @relation(fields: [studentId], references: [id])
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
}

// --- Audit log ---

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  entity    String
  entityId  String
  meta      String? // JSON
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}

// LAHEMATIX andmemudel — Faas 1 (autentimine + nõusolekud)
// NB! Faas 2 lisab: LessonPlan, ObservationProtocol, JournalEntry,
// Questionnaire/QuestionnaireResponse, TestVersion/TestSubmission.
// Need on siia juba kommentaarina ette valmistatud, aga mudelid
// lisatakse Faasis 2, et Faas 1 jääks väiksemaks ja kergemini
// ülevaadatavaks.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  TEADUR
  OPETAJA
  KOOLIJUHT
  LAPSEVANEM
}

enum Method {
  BOALER
  LILJEDAHL
  TOH
}

enum StudentGroup {
  INTERVENTSIOON
  KONTROLL
}

enum ConsentSubjectType {
  KOOLIJUHT
  OPETAJA
  LAPSEVANEM
  OPILANE_15PLUS
}

enum ConsentStatus {
  ANTUD
  TAGASI_VOETUD
}

enum AuthMethod {
  HARID // ei ole kasutusel (versioon 3 loobus HarID-st); säilib ainult skeemi ühilduvuse pärast
  TOKEN_URL
  DEV_LOGIN // endine ajutine paroolita sisselogimine; asendatud EMAIL_LINK'iga, säilib vanade kirjete jaoks
  EMAIL_LINK // magic-link sisselogimine (versioon 3, püsiv lahendus)
}

// Faas 2: InviteToken eesmärk — kas nõusolek (vaikimisi, olemasolevad read) või
// küsimustik (eel/järel). Küsimustiku token saadetakse alati õpilase enda e-postile,
// isegi alla 15-aastasele, kuna küsimustik käib õpilase enda kohta, mitte lapsevanema.
enum InvitePurpose {
  CONSENT
  QUESTIONNAIRE_EEL
  QUESTIONNAIRE_JAREL
  TEST_EEL
  TEST_JAREL
}

// Faas 2: matemaatilise probleemilahenduse test. Sama test käib eel- ja
// järelmõõtmisel (phase eristab neid), sisu on hardcoded src/lib/tests/-is.
enum TestPhase {
  EEL
  JAREL
}

// --- Kasutajad (täiskasvanud rollid) ---

model User {
  id             String   @id @default(cuid())
  role           Role
  email          String   @unique
  name           String
  haridSubjectId String?  @unique // täidetakse, kui HarID on ühendatud
  status         String   @default("ACTIVE") // ACTIVE | INVITED | DISABLED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // rollipõhised laiendused (valikulised, ainult üks täidetud vastavalt rollile)
  teacherProfile Teacher?

  auditLogs   AuditLog[]
  loginTokens LoginToken[]
  questionnaireResponses QuestionnaireResponse[]
  testGradings TestGrading[]

  @@index([role])
}

// Versioon 5: koolijuht ei ole enam eraldi kasutajakonto (vt arendusplaan punkt 1b) —
// tema nimi/e-post on lihtsalt väljad School'il, ja ta pääseb ligi ainult ühekordse
// token-URL-i kaudu (InviteToken), samamoodi nagu lapsevanem ja 15+ õpilane.

model School {
  id            String    @id @default(cuid())
  name          String
  directorName  String?
  directorEmail String?
  consentGiven  Boolean   @default(false)
  consentAt     DateTime?
  createdAt     DateTime  @default(now())

  teachers     Teacher[]
  inviteTokens InviteToken[]
}

model Teacher {
  id        String       @id @default(cuid())
  userId    String       @unique
  user      User         @relation(fields: [userId], references: [id])
  schoolId  String
  school    School       @relation(fields: [schoolId], references: [id])
  method    Method?
  group     StudentGroup @default(INTERVENTSIOON)
  gradeBand String? // "4-6" | "7-9" | "10-12"
  lisa8FirstViewedAt DateTime? // millal õpetaja Lisa 8 küsimustiku esimest korda avas — "alustatud, pooleli" märgistuseks
  createdAt DateTime     @default(now())

  students Student[]
  researchPlanEntries ResearchPlanEntry[]
  journalEntries      JournalEntry[]
}

// --- Õpilased (ei ole User — token-põhine ligipääs, vt InviteToken) ---
// Versioon 4: lapsevanem ei ole enam eraldi kasutajakonto (vt arendusplaan punkt 1a) —
// tema nimi/e-post on lihtsalt väljad Student'il, ja ta pääseb ligi ainult ühekordse
// token-URL-i kaudu (InviteToken), samamoodi nagu 15+ õpilane ise.

model Student {
  id                  String       @id @default(cuid())
  pseudonymCode       String       @unique // nt "OP-4F7A2B" — kasutatakse uurimisandmestikus (testid, küsimustikud)
  name                String       // õpilase pärisnimi — vajalik õpetaja klassivaate ja kutsete jaoks
  email               String       @unique // vajalik küsimustiku/testi kutsete saatmiseks
  classCode           String?      // vaba tekst, nt "5A" — õpetaja enda klassi/rühma silt, hilisemaks filtreerimiseks
  teacherId           String
  teacher             Teacher      @relation(fields: [teacherId], references: [id])
  group               StudentGroup
  birthYear           Int?
  gender              String?
  isFifteenOrOlder    Boolean      @default(false)
  parentName          String? // täidetud, kui alla 15a — ei ole eraldi kasutajakonto
  parentEmail         String? // täidetud, kui alla 15a — kutse/meeldetuletuse saatmiseks
  excludedFromAnalysis Boolean     @default(false)
  excludedAt          DateTime?
  createdAt           DateTime     @default(now())

  consentRecords ConsentRecord[]
  inviteTokens   InviteToken[]
  questionnaireResponses QuestionnaireResponse[]
  testSubmissions TestSubmission[]
}

// --- Nõusolekud ---

model ConsentRecord {
  id          String             @id @default(cuid())
  subjectType ConsentSubjectType
  // subjectId viitab: User.id (õpetaja), School.id (koolijuht, versioon 5) või
  // Student.id (lapsevanem, versioon 4; 15+ õpilane)
  subjectId   String
  studentId   String? // täidetud, kui nõusolek puudutab konkreetset last (lapsevanema puhul)
  student     Student?           @relation(fields: [studentId], references: [id])
  formVersion String             @default("v1")
  status      ConsentStatus      @default(ANTUD)
  givenAt     DateTime           @default(now())
  withdrawnAt DateTime?
  authMethod  AuthMethod
  // granulaarsed nõusolekukastid (Lisa 2 õpetaja vormi jaoks kolm eraldi kasti;
  // teiste vormide jaoks piisab esimesest väljast)
  detailsJson String? // JSON: { osalemine: true, vaatlus: true, intervjuu: false, ... }

  createdAt DateTime @default(now())

  @@index([subjectType, subjectId])
  @@index([studentId])
}

// --- Kutsed ja ühekordsed lingid ---

model InviteToken {
  id         String        @id @default(cuid())
  token      String        @unique
  // kutse sihtmärk: kas uus User (email+role täidetud), Student (studentId täidetud)
  // või School (schoolId täidetud, koolijuhi jaoks, versioon 5)
  email      String?
  role       Role?
  studentId  String?
  student    Student?      @relation(fields: [studentId], references: [id])
  schoolId   String?
  school     School?       @relation(fields: [schoolId], references: [id])
  purpose    InvitePurpose @default(CONSENT)
  expiresAt  DateTime
  usedAt     DateTime?
  firstViewedAt DateTime? // millal link esimest korda avati — "alustatud, kuid pooleli" märgistuse jaoks
  createdAt  DateTime      @default(now())
}

// --- Sisselogimislingid (magic link, versioon 3) ---

model LoginToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime // 15 minutit väljastamisest
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// --- Küsimustikud (Faas 2) ---
// Küsimustiku struktuur (plokid, väited) on hardcoded src/lib/questionnaires/-is,
// mitte DB-mudel — samamoodi nagu nõusolekuvormide tekst elab consentTexts.tsx-is.
// questionnaireCode viitab lihtsalt stringkoodile (nt "lisa4-eel", "lisa8"),
// samamoodi nagu ConsentRecord.formVersion on lihtne string, mitte FK.

model QuestionnaireResponse {
  id                String   @id @default(cuid())
  questionnaireCode String
  studentId         String?
  student           Student? @relation(fields: [studentId], references: [id])
  teacherUserId     String?
  teacherUser       User?    @relation(fields: [teacherUserId], references: [id])
  answersJson       String // { [blockKey]: { [itemKey]: string|number } }
  submittedAt       DateTime @default(now())

  @@unique([questionnaireCode, studentId])
  @@unique([questionnaireCode, teacherUserId])
}

// --- Matemaatilise probleemilahenduse test (Faas 2) ---
// Testi sisu (ülesanded, valikvastused, hindamisjuhend) on hardcoded
// src/lib/tests/-is, samamoodi nagu küsimustikud. Sama test käib eel- ja
// järelmõõtmisel ning nii kontroll- kui katserühmale — phase eristab
// mõõtmiskorda, testCode vanuseastet ("test-4-6" | "test-7-9" | "test-10-12").

model TestSubmission {
  id          String    @id @default(cuid())
  testCode    String
  phase       TestPhase
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  answersJson String? // null, kui ainult paberifotod; muidu { [probleemKey]: { [subKey]: { choice, explanation? } } }
  submittedAt DateTime? // täidetud, kui õpilane ise veebis sooritas
  createdAt   DateTime  @default(now())

  photos  TestSubmissionPhoto[]
  grading TestGrading?

  @@unique([testCode, phase, studentId])
}

model TestSubmissionPhoto {
  id               String         @id @default(cuid())
  testSubmissionId String
  testSubmission   TestSubmission @relation(fields: [testSubmissionId], references: [id])
  filePath         String // suhteline tee privaatses uploads-kaustas
  originalName     String
  uploadedAt       DateTime       @default(now())

  @@index([testSubmissionId])
}

model TestGrading {
  id               String         @id @default(cuid())
  testSubmissionId String         @unique
  testSubmission   TestSubmission @relation(fields: [testSubmissionId], references: [id])
  scoresJson       String // { [probleemKey]: { [subKey]: number } }
  totalScore       Int
  comment          String? // nähtav ainult õpetajale, teadurile ja adminile
  gradedByUserId   String
  gradedByUser     User           @relation(fields: [gradedByUserId], references: [id])
  gradedAt         DateTime       @default(now())
}

// --- Õpetaja isiklik uuringukava ja uurijapäevik (Faas 1 jätk, Lisa 7 + Lisa 10) ---
// Uuringukava rida kirjeldab ühte plaanitud katsetundi; õpetaja lisab/muudab/
// kustutab ridu ise jooksvalt (vt Lisa 10 juhis — tabel ei pea korraga täielik
// olema). lessonPlanUrl on lihtne vaba tekst/link — valmisolek täieliku
// tunnikavade (LessonPlan) funktsionaalsuse jaoks lisandub hiljem, praegu
// piisab sellest väljast lingi jaoks, kui tunnikava on mujal juba olemas.

model ResearchPlanEntry {
  id                String    @id @default(cuid())
  teacherId         String
  teacher           Teacher   @relation(fields: [teacherId], references: [id])
  date              DateTime
  startTime         String? // kellaaeg, nt "10:15"
  durationMin       Int?
  studentGroup      String? // nt "5A"
  appliedMethods    Method[]  @default([]) // selle tunni jooksul tegelikult rakendatud meetod(id)
  topic             String?
  lessonPlanUrl     String? // link tunnikavale, kui olemas — lisandub sageli hiljem
  expectingObserver Boolean   @default(false)
  observerName      String?
  hidden            Boolean   @default(false) // "Peida"/"Taasta" — pehme peitmine, mitte kustutamine
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  journalEntry JournalEntry?

  @@index([teacherId])
}

// Uurijapäeviku sissekanne (Lisa 7) — üks kindla katsetunni kohta, kirjutatakse
// kohe pärast tundi. Sisu (9 Likert-väidet + Rolfe'i refleksioon) on hardcoded
// src/lib/journal/-is, samamoodi nagu küsimustikud/testid. Õpetaja saab
// sissekannet hiljem täiendada/muuta — submittedAt on esmase salvestuse aeg,
// updatedAt uueneb iga muutmisega.

model JournalEntry {
  id                  String            @id @default(cuid())
  researchPlanEntryId String            @unique
  researchPlanEntry   ResearchPlanEntry @relation(fields: [researchPlanEntryId], references: [id])
  teacherId           String
  teacher             Teacher           @relation(fields: [teacherId], references: [id])
  answersJson         String // { likert: { [domainKey.itemKey]: { value, comment? } }, rolfe: { what: [s1,s2,s3], soWhat, nowWhat } }
  submittedAt         DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

// --- Audit log ---

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  entity    String
  entityId  String
  meta      String? // JSON
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}
